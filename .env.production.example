# ========================================
# TRAKERJA - PRODUCTION CONFIGURATION
# ========================================
# ⚠️ IMPORTANT: 
# - Copy this file to .env
# - NEVER commit .env to Git
# - Use strong, random passwords
# - Enable HTTPS in production
# ========================================

# Application Settings
APP_NAME=TraKerja
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://your-domain.com

# Localization
APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

# Maintenance Mode
APP_MAINTENANCE_DRIVER=file

# PHP Settings
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# Logging
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Database Configuration
# ⚠️ Use strong passwords in production!
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=trakerja_production
DB_USERNAME=trakerja_user
DB_PASSWORD=STRONG_RANDOM_PASSWORD_HERE

# Session Configuration
# ⚠️ CRITICAL: Enable encryption and secure cookies in production
SESSION_DRIVER=database
SESSION_LIFETIME=360
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.your-domain.com
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_EXPIRE_ON_CLOSE=false

# Broadcasting
BROADCAST_CONNECTION=log

# Filesystem
FILESYSTEM_DISK=local

# Queue Configuration
# ⚠️ Use redis or database for production
QUEUE_CONNECTION=database

# Cache Configuration
# ⚠️ RECOMMENDED: Use redis for production
CACHE_STORE=redis
CACHE_PREFIX=trakerja_cache

# Redis Configuration
# ⚠️ Install Redis for better performance
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DATABASE=0

# Email Configuration (SMTP)
# ⚠️ CRITICAL: Configure real SMTP for production
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-here
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@trakerja.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS (Optional - For S3 file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Error Tracking (Optional but RECOMMENDED)
# Sentry.io for error monitoring
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Analytics (Optional)
GOOGLE_ANALYTICS_ID=

# Security
# ⚠️ CRITICAL: Enable these in production
FORCE_HTTPS=true
ASSET_URL=https://your-domain.com

# Rate Limiting
# Adjust based on your traffic
THROTTLE_LIMIT=60
THROTTLE_DECAY=1

# File Upload Limits
MAX_UPLOAD_SIZE=2048
# In KB

# Vite
VITE_APP_NAME="${APP_NAME}"
